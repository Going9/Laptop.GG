[Unit]
Description=LaptopGG Spring Boot web application
After=network-online.target
Wants=network-online.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/laptopgg
EnvironmentFile=/home/ubuntu/laptopgg/laptopgg.env
ExecStart=/bin/sh -c '/usr/bin/java $JAVA_OPTS -jar /home/ubuntu/laptopgg/app.jar --spring.profiles.active=$SPRING_PROFILES_ACTIVE'
SuccessExitStatus=143
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
