SPRING_DATASOURCE_URL=jdbc:postgresql://10.0.0.10:5432/laptopgg
SPRING_DATASOURCE_USERNAME=laptopgg
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_PROFILES_ACTIVE=postgres,deploy
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=3
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SERVER_TOMCAT_THREADS_MAX=32
JAVA_OPTS=-Xms128m -Xmx384m -XX:TieredStopAtLevel=1 -Duser.timezone=Asia/Seoul
APP_BASE_URL=https://laptopgg.com
